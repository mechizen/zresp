# Cloudflare Tunnel (named tunnel) のトークン。
# ダッシュボードでトンネルを作成して取得し、公開ホスト名を http://app:8000 にルーティングする。
# `docker compose --profile tunnel up` で cloudflared が起動する。
TUNNEL_TOKEN=

# アプリ設定 (任意。環境変数は ZRESP_ プレフィックス)
# ZRESP_APP_NAME=zresp
# ZRESP_MAX_BYTES=104857600

# CORS (既定で全オリジン許可)。Cookie 等の credentialed リクエストを使う場合のみ、
# オリジンを具体的に絞り credentials を有効化する ("*" と credentials は併用不可)。
# ZRESP_CORS_ALLOW_ORIGINS=["https://app.example.com"]
# ZRESP_CORS_ALLOW_CREDENTIALS=true
